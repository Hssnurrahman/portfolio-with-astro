---
export interface Props {
  name: string;
  description: string;
  href?: string;
  tags?: string[];
  featured?: boolean;
}

const { name, description, href, tags = [], featured = false } = Astro.props as Props;
const visibleTags = tags.slice(0, 4);
const extraCount = tags.length - visibleTags.length;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    "group block h-full rounded-xl p-6 transition-all duration-300 border",
    "hover:-translate-y-1 hover:shadow-lg",
    featured
      ? "border-gray-900 dark:border-white bg-gray-900 dark:bg-white"
      : "border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-950 hover:border-gray-900 dark:hover:border-white",
  ]}
>
  <div class="flex flex-col h-full">
    <!-- Header -->
    <div class="flex items-start justify-between mb-3">
      <h3 class:list={[
        "text-xl font-bold",
        featured ? "text-white dark:text-gray-900" : "text-gray-900 dark:text-white",
      ]}>
        {name}
      </h3>
      <svg
        class:list={[
          "w-5 h-5 shrink-0 ml-2 mt-0.5 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5",
          featured
            ? "text-gray-400 dark:text-gray-600"
            : "text-gray-400 group-hover:text-gray-900 dark:group-hover:text-white",
        ]}
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
        ></path>
      </svg>
    </div>

    <!-- Description -->
    <p class:list={[
      "mb-6 flex-1 text-sm leading-relaxed",
      featured ? "text-gray-300 dark:text-gray-600" : "text-gray-600 dark:text-gray-400",
    ]}>
      {description}
    </p>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {visibleTags.map((tag: string) => (
          <span class:list={[
            "text-xs px-2.5 py-1 rounded-full font-medium",
            featured
              ? "bg-white/10 dark:bg-black/10 text-gray-200 dark:text-gray-700"
              : "bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300",
          ]}>
            {tag}
          </span>
        ))}
        {extraCount > 0 && (
          <span class:list={[
            "text-xs px-2.5 py-1 rounded-full font-medium",
            featured
              ? "bg-white/10 dark:bg-black/10 text-gray-400 dark:text-gray-500"
              : "bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-500",
          ]}>
            +{extraCount} more
          </span>
        )}
      </div>
    )}
  </div>
</a>
