---
import "../../global.css";

const colorMap: Record<string, string> = {
  indigo: "bg-indigo-500/10 text-indigo-400 border-indigo-500/20",
  violet: "bg-violet-500/10 text-violet-400 border-violet-500/20",
  green:  "bg-green-500/10 text-green-400 border-green-500/20",
  red:    "bg-red-500/10 text-red-400 border-red-500/20",
  blue:   "bg-blue-500/10 text-blue-400 border-blue-500/20",
  yellow: "bg-yellow-500/10 text-yellow-400 border-yellow-500/20",
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/ledgerflow-icon.png" />
    <meta name="description" content="LedgerFlow — Smart business ledger app for managing customer credit, debit, and analytics. Available on Android." />
    <meta property="og:title" content="LedgerFlow — Smart Business Ledger" />
    <meta property="og:description" content="Manage customer transactions, track balances, and get powerful analytics — all offline." />
    <meta property="og:image" content="/ledgerflow-icon.png" />
    <title>LedgerFlow — Smart Business Ledger</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>

  <body class="bg-[#0F172A] text-white font-['Inter'] antialiased">

    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-[#0F172A]/80 border-b border-white/5">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <img src="/ledgerflow-icon.png" alt="LedgerFlow" class="w-9 h-9 rounded-xl" />
          <span class="font-bold text-lg tracking-tight">LedgerFlow</span>
        </div>
        <div class="hidden sm:flex items-center gap-8 text-sm text-gray-400">
          <a href="#features" class="hover:text-white transition-colors">Features</a>
          <a href="#screenshots" class="hover:text-white transition-colors">Screenshots</a>
          <a href="#download" class="hover:text-white transition-colors">Download</a>
        </div>
        <a
          href="#download"
          class="px-4 py-2 rounded-lg text-sm font-medium bg-indigo-600 hover:bg-indigo-500 transition-colors"
        >
          Get App
        </a>
      </div>
    </nav>

    <!-- Hero -->
    <section class="min-h-screen flex items-center pt-20 relative overflow-hidden">
      <!-- Background glow -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-indigo-600/10 rounded-full blur-[120px] pointer-events-none"></div>
      <div class="absolute top-1/3 left-1/4 w-[400px] h-[400px] bg-violet-600/8 rounded-full blur-[100px] pointer-events-none"></div>

      <div class="max-w-6xl mx-auto px-6 py-24 w-full relative">
        <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">

          <!-- Text -->
          <div class="flex-1 text-center lg:text-left space-y-8">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 text-sm font-medium">
              <span class="w-2 h-2 rounded-full bg-indigo-400 animate-pulse"></span>
              Available on Android
            </div>

            <div class="space-y-4">
              <h1 class="text-5xl lg:text-7xl font-extrabold leading-tight tracking-tight">
                Business ledger,
                <span class="bg-gradient-to-r from-indigo-400 to-violet-400 bg-clip-text text-transparent">
                  simplified.
                </span>
              </h1>
              <p class="text-xl text-gray-400 max-w-xl leading-relaxed mx-auto lg:mx-0">
                Track customer credit & debit, monitor your cash flow, and get powerful analytics — all stored locally on your device. No subscription. No cloud required.
              </p>
            </div>

            <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
              <a
                href="#download"
                class="flex items-center justify-center gap-3 px-8 py-4 rounded-xl bg-indigo-600 hover:bg-indigo-500 transition-all font-semibold text-white shadow-lg shadow-indigo-600/25"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.523 15.341 14 8.191V2h1a1 1 0 0 0 0-2H9a1 1 0 0 0 0 2h1v6.191l-3.523 7.15A5 5 0 0 0 11 22h2a5 5 0 0 0 4.523-6.659zM12 20h-1a3 3 0 0 1-2.716-4.288L11 9.48V8h2v1.48l2.716 6.232A3 3 0 0 1 13 20z"/>
                </svg>
                Download APK
              </a>
              <a
                href="#features"
                class="flex items-center justify-center gap-3 px-8 py-4 rounded-xl border border-white/10 hover:bg-white/5 transition-all font-medium text-gray-300"
              >
                Explore Features
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m9 18 6-6-6-6"/>
                </svg>
              </a>
            </div>

            <!-- Stats -->
            <div class="flex gap-8 justify-center lg:justify-start pt-4">
              <div>
                <div class="text-3xl font-bold">50+</div>
                <div class="text-sm text-gray-500">Projects tracked</div>
              </div>
              <div class="w-px bg-white/10"></div>
              <div>
                <div class="text-3xl font-bold">0</div>
                <div class="text-sm text-gray-500">Data sent to cloud</div>
              </div>
              <div class="w-px bg-white/10"></div>
              <div>
                <div class="text-3xl font-bold">Free</div>
                <div class="text-sm text-gray-500">Forever</div>
              </div>
            </div>
          </div>

          <!-- App icon mockup -->
          <div class="flex-shrink-0 relative">
            <div class="relative w-48 h-48 lg:w-64 lg:h-64">
              <div class="absolute inset-0 bg-gradient-to-br from-indigo-500 to-violet-600 rounded-[2.5rem] lg:rounded-[3rem] blur-2xl opacity-40"></div>
              <img
                src="/ledgerflow-icon.png"
                alt="LedgerFlow App"
                class="relative w-full h-full rounded-[2.5rem] lg:rounded-[3rem] shadow-2xl shadow-indigo-900/60"
              />
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="py-28 relative">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center space-y-4 mb-20">
          <h2 class="text-4xl lg:text-5xl font-bold">Everything you need</h2>
          <p class="text-gray-400 text-lg max-w-xl mx-auto">A complete toolkit for managing your business finances, built for speed and simplicity.</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

          <!-- Feature cards -->
          {[
            {
              icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>`,
              title: "Customer Management",
              desc: "Add customers with name, phone, address, and notes. Search, filter by balance status, and sort any way you like.",
              color: "indigo",
            },
            {
              icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>`,
              title: "Credit & Debit Tracking",
              desc: "Record \"You Gave\" and \"You Received\" transactions with real-time running balance per customer.",
              color: "violet",
            },
            {
              icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" /></svg>`,
              title: "Analytics & Reports",
              desc: "Monthly trend charts, balance pie charts, top customer bar charts. Export as PDF or CSV.",
              color: "green",
            },
            {
              icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" /></svg>`,
              title: "Biometric Security",
              desc: "Protect your business data with fingerprint or PIN-based app lock. Secure storage for sensitive credentials.",
              color: "red",
            },
            {
              icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 2.625c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125m16.5 5.625c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>`,
              title: "Backup & Restore",
              desc: "Local device backup or Google Drive cloud sync. Never lose your data even if you change phones.",
              color: "blue",
            },
            {
              icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016 2.993 2.993 0 0 0 2.25-1.016 3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z" /></svg>`,
              title: "Multiple Businesses",
              desc: "Create and switch between multiple businesses, each with their own independent customer and transaction data.",
              color: "yellow",
            },
          ].map(({ icon, title, desc, color }) => (
            <div class="p-6 rounded-2xl bg-white/[0.03] border border-white/8 hover:bg-white/[0.06] transition-colors group">
              <div class={`w-12 h-12 rounded-xl border flex items-center justify-center mb-5 ${colorMap[color]}`} set:html={icon} />
              <h3 class="font-semibold text-lg mb-2">{title}</h3>
              <p class="text-gray-400 text-sm leading-relaxed">{desc}</p>
            </div>
          ))}

        </div>
      </div>
    </section>

    <!-- Built-in Calculator callout -->
    <section class="py-16">
      <div class="max-w-6xl mx-auto px-6">
        <div class="rounded-2xl bg-gradient-to-r from-indigo-600/20 to-violet-600/20 border border-indigo-500/20 p-8 lg:p-12 flex flex-col lg:flex-row items-center gap-8 text-center lg:text-left">
          <div class="flex-shrink-0 w-16 h-16 rounded-2xl bg-indigo-500/20 border border-indigo-500/30 flex items-center justify-center text-indigo-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25V13.5Zm0 2.25h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25V18Zm2.498-6.75h.007v.008h-.007v-.008Zm0 2.25h.007v.008h-.007V13.5Zm0 2.25h.007v.008h-.007v-.008Zm0 2.25h.007v.008h-.007V18Zm2.504-6.75h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V13.5Zm0 2.25h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V18Zm2.498-6.75h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V13.5ZM8.25 6h7.5v2.25h-7.5V6ZM12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25Z" />
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="text-2xl font-bold mb-2">Built-in Calculator</h3>
            <p class="text-gray-400 max-w-2xl">Enter transaction amounts with full math expressions — <code class="text-indigo-400 bg-indigo-500/10 px-1.5 py-0.5 rounded text-sm">500 + 250 - 100</code> — and LedgerFlow calculates the result inline before saving. No switching apps.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Screenshots placeholder section -->
    <section id="screenshots" class="py-28">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center space-y-4 mb-16">
          <h2 class="text-4xl lg:text-5xl font-bold">Clean. Fast. Intuitive.</h2>
          <p class="text-gray-400 text-lg max-w-lg mx-auto">Material Design 3 with an Indigo & Violet palette. Dark mode included out of the box.</p>
        </div>

        <!-- Design preview cards showing key screens -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          {[
            { label: "Dashboard", color: "from-indigo-900/60 to-indigo-800/30", icon: "M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" },
            { label: "Customers", color: "from-violet-900/60 to-violet-800/30", icon: "M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" },
            { label: "Reports", color: "from-green-900/60 to-green-800/30", icon: "M7.5 14.25v2.25m3-4.5v4.5m3-6.75v6.75m3-9v9M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25Z" },
            { label: "Settings", color: "from-slate-800/80 to-slate-700/30", icon: "M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" },
          ].map(({ label, color, icon }) => (
            <div class={`aspect-[9/16] rounded-2xl bg-gradient-to-br ${color} border border-white/10 flex flex-col items-center justify-center gap-4 p-6`}>
              <div class="w-14 h-14 rounded-2xl bg-white/10 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
                </svg>
              </div>
              <span class="text-sm font-medium text-white/60">{label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Download CTA -->
    <section id="download" class="py-28">
      <div class="max-w-6xl mx-auto px-6">
        <div class="rounded-3xl bg-gradient-to-br from-indigo-600 to-violet-700 p-1">
          <div class="rounded-[calc(1.5rem-4px)] bg-[#0F172A] p-12 lg:p-20 text-center space-y-8">
            <img src="/ledgerflow-icon.png" alt="LedgerFlow" class="w-24 h-24 rounded-3xl mx-auto shadow-xl shadow-indigo-900/60" />
            <div class="space-y-4">
              <h2 class="text-4xl lg:text-5xl font-extrabold">Start for free today</h2>
              <p class="text-gray-400 text-lg max-w-md mx-auto">No sign-up. No subscription. Your data stays on your device.</p>
            </div>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a
                href="https://github.com/Hssnurrahman"
                target="_blank"
                class="inline-flex items-center justify-center gap-3 px-8 py-4 rounded-xl bg-indigo-600 hover:bg-indigo-500 transition-all font-semibold text-white shadow-lg shadow-indigo-600/30"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                View on GitHub
              </a>
              <a
                href="https://hssan.dev"
                class="inline-flex items-center justify-center gap-3 px-8 py-4 rounded-xl border border-white/15 hover:bg-white/5 transition-all font-medium text-gray-300"
